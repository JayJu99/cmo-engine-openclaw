# Dashboard adapter mode
# Production/default Phase 1.2 path should use the VPS adapter boundary.
CMO_ADAPTER_MODE=local
CMO_REMOTE_ADAPTER_URL=
CMO_REMOTE_ADAPTER_API_KEY=

# Hermes agent execution
# Hermes CMO runtime posts to {CMO_HERMES_BASE_URL}/agents/cmo/execute.
CMO_HERMES_EXECUTION_ENABLED=false
CMO_HERMES_BASE_URL=
CMO_HERMES_API_KEY=
CMO_HERMES_TIMEOUT_MS=240000
CMO_VAULT_INGEST_API_KEY=

# Hermes CMO app-chat routing
# Hermes CMO chat stays disabled by default and limits rollout to canary apps.
CMO_HERMES_CMO_CHAT_ENABLED=false
CMO_HERMES_CMO_CANARY_APPS=holdstation-mini-app
CMO_HERMES_CMO_CHAT_V11_ENABLED=false
CMO_HERMES_CMO_CHAT_V11_CANARY_APPS=hold-pay
CMO_HERMES_CMO_CHAT_V11_FALLBACK_ENABLED=false
# M1 orchestration lets Hermes CMO emit bounded Echo/Surf delegations executed by CMO Engine.
CMO_HERMES_CMO_ORCHESTRATION_ENABLED=false
CMO_HERMES_CMO_MAX_DELEGATIONS=2
# M3 Vault Agent handoff remains backend-only when enabled.
# off | dry_run | dry_run_remote | write_remote
CMO_VAULT_AGENT_HANDOFF_MODE=off

# off | pilot_remote
CMO_VAULT_CONTEXT_PACK_MODE=off

# Lens connector broker
# Direct Lens readout injection into CMO chat is debug-only; default false keeps Hermes Lens as runtime source.
CMO_LENS_DIRECT_CONTEXT_ENABLED=false
# Internal server-to-server key for Hermes Lens -> Product metrics connector.
CMO_LENS_INTERNAL_API_KEY=

# Product-owned native Dune business connector.
# Server-side only. Never prefix with NEXT_PUBLIC_ and never expose in frontend/logs.
CMO_DUNE_API_KEY=
CMO_DUNE_NATIVE_ENABLED=false
CMO_DUNE_NATIVE_DASHBOARD_ENABLED=false

# Product-owned native Meta/Facebook Page connector.
# Server-side only. Never prefix with NEXT_PUBLIC_ and never expose tokens in frontend/logs.
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3002/api/cmo/oauth/meta/callback
CMO_FACEBOOK_NATIVE_ENABLED=false
CMO_FACEBOOK_NATIVE_DASHBOARD_ENABLED=false

# App-scoped OpenClaw CMO chat runtime
# Optional dev/direct endpoint. Ignored when CMO_ADAPTER_MODE=remote and the remote adapter URL/key are set.
OPENCLAW_CMO_ENDPOINT=
OPENCLAW_API_KEY=
OPENCLAW_WORKSPACE_ID=
OPENCLAW_CMO_TIMEOUT_MS=60000
CMO_LIVE_APP_TURN_TIMEOUT_MS=240000
CMO_FALLBACK_FAST_AFTER_MS=240000

# Remote adapter path required envs on the Next.js side:
# CMO_ADAPTER_MODE=remote
# CMO_REMOTE_ADAPTER_URL=https://your-adapter.example.com
# CMO_REMOTE_ADAPTER_API_KEY=your-adapter-key

# Dashboard Basic Auth
DASHBOARD_BASIC_AUTH_ENABLED=false
DASHBOARD_BASIC_AUTH_USERNAME=
DASHBOARD_BASIC_AUTH_PASSWORD=

# Supabase Auth foundation
# NEXT_PUBLIC_* values are safe for browser clients.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. Never import into client components.
SUPABASE_SERVICE_ROLE_KEY=
CMO_AUTH_ENABLED=false
CMO_AUTH_REQUIRED=false
CMO_SUPABASE_INDEXING_ENABLED=false
CMO_INDEXED_CONTEXT_ENABLED=false
CMO_INDEXED_CONTEXT_CANARY_APPS=holdstation-mini-app
CMO_INDEXED_CONTEXT_MODE=supplemental
CMO_OWNER_EMAIL=
CMO_PUBLIC_APP_URL=https://cmo.jayju.cloud

# Lens Google OAuth foundation
# Server-side only. Do not prefix these with NEXT_PUBLIC_.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3002/api/lens/oauth/google/callback
LENS_OAUTH_STATE_SECRET=
LENS_OAUTH_TOKEN_ENCRYPTION_KEY=

# VPS CMO Adapter service
# CMO_ADAPTER_API_KEY must match CMO_REMOTE_ADAPTER_API_KEY on the Next.js side.
CMO_ADAPTER_API_KEY=
CMO_DASHBOARD_DATA_DIR=/home/ju/.openclaw/workspace/data/cmo-dashboard
CMO_SCHEMA_VERSION=cmo.dashboard.v1
CMO_TRIGGER_MODE=mock
OPENCLAW_BIN=openclaw
CMO_AGENT_ID=cmo
CMO_RUN_TIMEOUT_SECONDS=900
CMO_CHAT_TIMEOUT_SECONDS=900
CMO_CRON_RUN_TIMEOUT_MS=180000
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_TIMEOUT_MS=120000
CMO_ADAPTER_HOST=0.0.0.0
CMO_ADAPTER_PORT=8787
