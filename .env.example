# Dashboard adapter mode
# Production/default Phase 1.2 path should use the VPS adapter boundary.
CMO_ADAPTER_MODE=local
CMO_REMOTE_ADAPTER_URL=
CMO_REMOTE_ADAPTER_API_KEY=

# Hermes agent execution
# H5 Hermes CMO live adapter posts to {CMO_HERMES_BASE_URL}/agents/cmo/execute.
CMO_HERMES_EXECUTION_ENABLED=false
CMO_HERMES_BASE_URL=
CMO_HERMES_API_KEY=
CMO_HERMES_TIMEOUT_MS=30000

# Hermes CMO app-chat routing
# H6 keeps Hermes CMO chat disabled by default and limits rollout to canary apps.
CMO_HERMES_CMO_CHAT_ENABLED=false
CMO_HERMES_CMO_CANARY_APPS=holdstation-mini-app

# App-scoped OpenClaw CMO chat runtime
# Optional dev/direct endpoint. Ignored when CMO_ADAPTER_MODE=remote and the remote adapter URL/key are set.
OPENCLAW_CMO_ENDPOINT=
OPENCLAW_API_KEY=
OPENCLAW_WORKSPACE_ID=
OPENCLAW_CMO_TIMEOUT_MS=60000
CMO_LIVE_APP_TURN_TIMEOUT_MS=12000
CMO_FALLBACK_FAST_AFTER_MS=12000

# Remote adapter path required envs on the Next.js side:
# CMO_ADAPTER_MODE=remote
# CMO_REMOTE_ADAPTER_URL=https://your-adapter.example.com
# CMO_REMOTE_ADAPTER_API_KEY=your-adapter-key

# Dashboard Basic Auth
DASHBOARD_BASIC_AUTH_ENABLED=false
DASHBOARD_BASIC_AUTH_USERNAME=
DASHBOARD_BASIC_AUTH_PASSWORD=

# Supabase Auth foundation
# NEXT_PUBLIC_* values are safe for browser clients.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. Never import into client components.
SUPABASE_SERVICE_ROLE_KEY=
CMO_AUTH_ENABLED=false
CMO_AUTH_REQUIRED=false
CMO_SUPABASE_INDEXING_ENABLED=false
CMO_INDEXED_CONTEXT_ENABLED=false
CMO_INDEXED_CONTEXT_CANARY_APPS=holdstation-mini-app
CMO_INDEXED_CONTEXT_MODE=supplemental
CMO_OWNER_EMAIL=
CMO_PUBLIC_APP_URL=https://cmo.jayju.cloud

# VPS CMO Adapter service
# CMO_ADAPTER_API_KEY must match CMO_REMOTE_ADAPTER_API_KEY on the Next.js side.
CMO_ADAPTER_API_KEY=
CMO_DASHBOARD_DATA_DIR=/home/ju/.openclaw/workspace/data/cmo-dashboard
CMO_SCHEMA_VERSION=cmo.dashboard.v1
CMO_TRIGGER_MODE=mock
OPENCLAW_BIN=openclaw
CMO_AGENT_ID=cmo
CMO_RUN_TIMEOUT_SECONDS=900
CMO_CHAT_TIMEOUT_SECONDS=900
CMO_CRON_RUN_TIMEOUT_MS=180000
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_TIMEOUT_MS=120000
CMO_ADAPTER_HOST=0.0.0.0
CMO_ADAPTER_PORT=8787
